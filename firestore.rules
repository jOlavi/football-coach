rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    function isCoach(teamId) {
      return request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.coaches;
    }

    match /teams/{teamId} {
      allow get, update, delete: if isCoach(teamId);
      allow list: if request.auth != null
        && request.auth.uid in resource.data.coaches;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.headCoachId
        && request.resource.data.coaches.hasAll([request.auth.uid]);

      match /{subcollection}/{docId} {
        allow read, write: if isCoach(teamId);
      }
    }

    match /users/{userId}/sports/{sport}/{collection}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /globalExercises/{sport}/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /invitations/{token} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && isCoach(request.resource.data.teamId);
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used'])
        && request.resource.data.used == true;
    }
  }
}
